// Lumo Prisma schema — TRD §9–10. Money in kobo (Int). All ids cuid.
// Enums mirrored in packages/shared/src/enums.ts — keep in sync.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Supabase pooled (pgbouncer, :6543) — app runtime
  directUrl = env("DIRECT_URL") // Supabase direct (:5432) — migrations
}

// ───────────────────────── Enums ─────────────────────────

enum Role {
  BUYER
  SELLER
  ADMIN
  SUPER_ADMIN
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  EXPIRED
  SOLD
  DELETED
}

enum Condition {
  NEW
  USED
  FOR_PARTS
}

enum VerificationStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentPurpose {
  PROMOTION
  SUBSCRIPTION
  VERIFICATION
  FEATURED
}

enum PromotionTier {
  NONE
  BOOST
  TOP
  DIAMOND
  ENTERPRISE
}

enum ReviewReason {
  SPOT_CHECK
  REPORTED
  MANUAL_FLAG
}

enum ReviewState {
  OPEN
  CLEARED
  ACTIONED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  ABANDONED
}

enum ReportReason {
  SCAM
  PROHIBITED
  DUPLICATE
  MISCATEGORISED
  ALREADY_SOLD
  OTHER
}

// ───────────────────────── Models ─────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  roles         Role[]    @default([BUYER])
  emailVerified Boolean   @default(false)
  phoneVerified Boolean   @default(false)
  avatarUrl     String?
  state         String?
  city          String?
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  sellerProfile   SellerProfile?
  listings        Listing[]
  favorites       Favorite[]
  reports         Report[]
  payments        Payment[]
  notifications   Notification[]
  refreshTokens   RefreshToken[]
  subscriptions   SellerSubscription[]
  messages        Message[]
  buyerChats      Chat[]               @relation("BuyerChats")
  sellerChats     Chat[]               @relation("SellerChats")
  reviewsReceived Review[]             @relation("ReviewsReceived")
  reviewsWritten  Review[]             @relation("ReviewsWritten")
  verificationRequests VerificationRequest[]
  contactReveals  ContactReveal[]
  savedSearches   SavedSearch[]
  priceWatches    PriceWatch[]
}

// Seller verification submission (TRD §22 — docs in a private bucket). Fee gating in Phase 5.
model VerificationRequest {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       VerificationStatus @default(PENDING)
  feePaid      Boolean            @default(false) // gate: admin reviews only after the verification fee is paid
  businessName String?
  docs         Json // [{ url, publicId, type }] — private Cloudinary assets
  reason       String? // rejection reason
  reviewerId   String?
  reviewedAt   DateTime?
  createdAt    DateTime           @default(now())

  @@index([status])
  @@index([userId])
}

// Rotating refresh tokens with reuse detection (TRD §7). One row per issued token;
// a session "family" is chained via replacedById so reuse of a rotated token can
// revoke the whole family.
model RefreshToken {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  familyId     String
  replacedById String?   @unique
  replacedBy   RefreshToken?  @relation("TokenRotation", fields: [replacedById], references: [id])
  rotatedFrom  RefreshToken?  @relation("TokenRotation")
  revokedAt    DateTime?
  expiresAt    DateTime
  userAgent    String?
  ip           String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}

model SellerProfile {
  id            String             @id @default(cuid())
  userId        String             @unique
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  verification  VerificationStatus @default(NONE)
  verifiedAt    DateTime?
  ratingAvg     Float              @default(0)
  ratingCount   Int                @default(0)
  isFeatured    Boolean            @default(false)
  featuredUntil DateTime?
  avgReplyHours Float?
}

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("Sub", fields: [parentId], references: [id])
  children Category[] @relation("Sub")
  order    Int        @default(0)
  attributeSchema Json?
  description String?
  listings Listing[]
}

model Listing {
  id            String         @id @default(cuid())
  slug          String         @unique
  title         String
  description   String
  priceKobo     Int
  condition     Condition      @default(USED)
  status        ListingStatus  @default(PENDING)
  state         String
  city          String // city/LGA
  area          String? // local area/market
  categoryId    String
  category      Category       @relation(fields: [categoryId], references: [id])
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id])
  images        ListingImage[]
  favorites     Favorite[]
  chats         Chat[]
  reports       Report[]
  contactReveals ContactReveal[]
  reviews       Review[]
  priceWatches  PriceWatch[]
  moderationReviews ModerationReview[]
  isPromoted    Boolean        @default(false)
  promotedUntil DateTime?
  promotionTier   PromotionTier  @default(NONE)
  attributes      Json?
  contactPhone    String?
  marketLowKobo   Int?
  marketHighKobo  Int?
  expiresAt              DateTime
  viewsCount             Int       @default(0)
  lastFreshnessNudgeAt   DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  @@index([status, categoryId, state, city])
  @@index([status, isPromoted, createdAt])
  @@index([status, createdAt])
}

// Post-publish review sample for auto-approved listings (spot-check safety net), plus user
// reports and manual admin flags — one queue, one feedback path into the trust gate via
// rejectListing/suspendListing (ACTIONED reviews are just REJECTED/SUSPENDED listings).
model ModerationReview {
  id         String       @id @default(cuid())
  listingId  String
  listing    Listing      @relation(fields: [listingId], references: [id])
  sellerId   String // denormalised for per-seller probation/metrics queries
  reason     ReviewReason
  state      ReviewState  @default(OPEN)
  createdAt  DateTime     @default(now())
  reviewedAt DateTime?
  reviewedBy String?
  outcome    String? // free-text note on ACTIONED reviews

  @@index([state, createdAt])
  @@index([sellerId, state])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  publicId  String // Cloudinary id for deletion
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  @@index([listingId])
}

model Favorite {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, listingId])
  @@index([listingId])
}

// One row per buyer who revealed a listing's contact — a durable "lead" signal.
// Unique per (listing, user) so it counts distinct interested buyers, not raw clicks.
model ContactReveal {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, listingId])
  @@index([listingId])
}

model Chat {
  id        String    @id @default(cuid())
  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User      @relation("BuyerChats", fields: [buyerId], references: [id])
  sellerId  String
  seller    User      @relation("SellerChats", fields: [sellerId], references: [id])
  createdAt DateTime  @default(now())
  messages  Message[]

  @@unique([listingId, buyerId, sellerId])
}

model Message {
  id        String    @id @default(cuid())
  chatId    String
  chat      Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User      @relation(fields: [senderId], references: [id])
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([chatId, createdAt])
}

model Report {
  id         String       @id @default(cuid())
  listingId  String
  listing    Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User         @relation(fields: [reporterId], references: [id])
  reason     ReportReason
  details    String?
  resolved   Boolean      @default(false)
  createdAt  DateTime     @default(now())

  @@unique([listingId, reporterId])
  @@index([resolved])
}

model PromotionPackage {
  id        String        @id @default(cuid())
  name      String
  days      Int
  priceKobo Int
  tier      PromotionTier @default(BOOST) // drives search ranking weight (lib/search.ts TIER_WEIGHT)
  active    Boolean       @default(true)
}

model SubscriptionPlan {
  id           String               @id @default(cuid())
  name         String
  priceKobo    Int
  listingLimit Int
  promoCredits Int
  features     Json
  active       Boolean              @default(true)
  subscriptions SellerSubscription[]
}

model SellerSubscription {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  startedAt DateTime         @default(now())
  expiresAt DateTime
  active    Boolean          @default(true)

  @@index([userId])
  @@index([active, expiresAt])
}

model Payment {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  purpose    PaymentPurpose
  amountKobo Int
  status     PaymentStatus  @default(PENDING)
  reference  String         @unique // Paystack reference
  targetId   String? // listingId / planId / verification req id
  metadata   Json?
  createdAt  DateTime       @default(now())

  @@index([userId])
  @@index([status])
}

model Review {
  id        String   @id @default(cuid())
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  sellerId  String
  seller    User     @relation("ReviewsReceived", fields: [sellerId], references: [id])
  authorId  String
  author    User     @relation("ReviewsWritten", fields: [authorId], references: [id])
  rating    Int
  body      String?
  createdAt DateTime @default(now())

  @@index([sellerId])
  // listingId is nullable (SetNull on listing delete keeps the review) — Postgres treats NULLs
  // as distinct, so deleted-listing reviews stay unconstrained, which is intended.
  @@unique([listingId, authorId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([actorId])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// Public "join the team" submissions from /careers — reviewed by SUPER_ADMIN, who then
// manually grants ADMIN after the applicant registers a normal account (no auto-promotion).
model StaffApplication {
  id         String            @id @default(cuid())
  name       String
  email      String
  message    String?
  status     ApplicationStatus @default(PENDING)
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime          @default(now())

  @@index([status])
}

model SavedSearch {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String?
  query         String?
  categoryId    String?
  state         String?
  minPriceKobo  Int?
  maxPriceKobo  Int?
  condition     Condition?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
}

model PriceWatch {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  priceKobo   Int
  createdAt   DateTime @default(now())

  @@unique([userId, listingId])
  @@index([listingId])
}
